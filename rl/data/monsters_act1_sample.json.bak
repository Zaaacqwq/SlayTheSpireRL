{
  "_meta": {
    "source": "Personally observed via mcp__sts2__get_game_state during the Phase A verification playthrough on 2026-07-09 (Ironclad, Act 1, floors 2-17). No API exposes monster stat data (get_compendium's bestiary is 'locked_in_ui', search_wiki only covers card/relic) -- this is the only clean-room source available.",
    "limitation": "Not exhaustive. Only regular (non-elite, non-boss) Act 1 monsters whose signature mechanic fits v1's approved power set (Strength/Dexterity, Vulnerable/Weak/Frail). Monsters with mechanics outside that set were deliberately excluded from v1 and are listed under excluded_for_v2 below rather than modeled inaccurately.",
    "excluded_for_v2": {
      "INKLET": "Slippery (first hit vs it is capped at 1 damage) -- not in v1's power set.",
      "SLITHERING_STRANGLER": "Constrict (player loses stacking HP at end of their own turn while it's alive) -- not in v1's power set.",
      "BYRDONIS": "Elite; Territorial (permanent +1 Strength every enemy-turn end) plus multi-hit scaling -- deferred, elites are out of v1 scope.",
      "VANTOM": "Boss; Slippery x8 plus large scripted burst turns -- deferred, bosses are out of v1 scope."
    },
    "ai_model": "Each monster has a repeating `ai_cycle`: a list of turn-effect dicts, cycled by `turn_index % len(ai_cycle)`. A turn-effect dict may include any of `attack` ({amount, hits}), `buff_strength` (amount), `block` (amount gained on its own turn), `debuff_player_weak` (number of standard 25%-Weak stacks applied to the player -- approximate stand-in for effects whose exact mechanic wasn't legible in the observed game state, e.g. Shrinker Beetle's real 30% Shrink effect). `attack.amount` is the intrinsic/base value; the simulator's generic Strength-affects-damage formula (shared with the player) applies the monster's current Strength on top of it, so accumulated buffs scale future attacks automatically -- this is exactly how the real fights played out (e.g. Fuzzy Wurm Crawler's attack went from 3 to 11 after a single +7 Strength turn)."
  },
  "monsters": {
